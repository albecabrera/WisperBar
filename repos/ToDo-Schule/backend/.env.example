# =============================================================================
#  ToDo-Schule Backend — Umgebungsvariablen
#  Kopiere diese Datei nach ".env" und passe die Werte an.
#      cp .env.example .env
# =============================================================================

# --- Server -------------------------------------------------------------------
APP_ENV=development                 # development | production
APP_DEBUG=true                      # true zeigt Stacktraces im JSON-Fehler an
HTTP_PORT=8080                       # nur informativ (Webserver/Docroot setzt das)

# --- Datenbank (MySQL / MariaDB) ---------------------------------------------
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=todo_schule
DB_USERNAME=root
DB_PASSWORD=
DB_PERSISTENT=true                  # PDO Connection Pooling (persistente Verbindung)

# --- JWT ----------------------------------------------------------------------
# WICHTIG: In Produktion durch lange, zufällige Secrets ersetzen!
#   php -r "echo bin2hex(random_bytes(32));"
JWT_ACCESS_SECRET=change-me-access-secret-please-32-bytes-min
JWT_REFRESH_SECRET=change-me-refresh-secret-please-32-bytes-min
JWT_ACCESS_TTL=900                   # Access-Token-Lebensdauer in Sekunden (15 min)
JWT_REFRESH_TTL=1209600             # Refresh-Token-Lebensdauer in Sekunden (14 Tage)
JWT_ISSUER=todo-schule

# --- CORS ---------------------------------------------------------------------
# Origin der PWA. Mehrere mit Komma trennen. "*" nur für lokale Entwicklung.
ALLOWED_ORIGIN=http://localhost:5173

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_BACKEND=file              # file | db
RATE_LIMIT_AUTH_MAX=10               # max. Anfragen je Auth-Endpoint
RATE_LIMIT_AUTH_WINDOW=60            # Zeitfenster in Sekunden

# --- WebSocket-Server ---------------------------------------------------------
WS_HOST=0.0.0.0
WS_PORT=8090
WS_POLL_INTERVAL=1.0                 # Event-Tabelle alle N Sekunden abfragen
