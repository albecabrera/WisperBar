{
  "name": "todo-schule/backend",
  "description": "Backend (PHP + MySQL) für die ToDo-Schule Kollaborations-PWA — abhängigkeitsfrei.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S 0.0.0.0:8080 -t public",
    "ws": "php bin/ws-server.php"
  }
}
